APP_NAME=PIPAA
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://example.com

ADMIN_EMAIL=admin@pipaa.tj
ADMIN_PASSWORD=
ADMIN_NAME="PIPAA Admin"

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database
PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info
LOG_STDERR_FORMATTER=

DB_CONNECTION=pgsql
DATABASE_URL=
DB_HOST=
DB_PORT=5432
DB_DATABASE=pipaart_db
DB_USERNAME=
DB_PASSWORD=
DB_SCHEMA=public
DB_SSLMODE=prefer

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS="info@pipaa.tj"
MAIL_FROM_NAME="${APP_NAME}"

CONTACT_RECIPIENT_EMAIL=info@pipaa.tj
CONTACT_BACKUP_EMAIL=pipaart@mail.ru
CONTACT_PHONE=+992935603338
CONTACT_ADDRESS="Dushanbe, Tajikistan"
CMS_SITE_NAME=PIPAA

SMS_ENABLED=false
SMS_API_URL=
SMS_API_TOKEN=
SMS_TO=
SMS_SENDER=PIPAA
SMS_TIMEOUT=5

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
